{
  "manifest_version": 2,
  "name": "Argus Beta",
  "version": "360.2.0.0",
  "description": "Analyze any webpage using Grok, ChatGPT, Claude, or Gemini. Custom prompts, OSINT tools, streaming responses, multi-provider comparison, analysis history, and more.",

  "browser_specific_settings": {
    "gecko": {
      "id": "argus-beta@local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "tabs",
    "alarms",
    "<all_urls>",
    "https://api.x.ai/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.opensanctions.org/*",
    "https://efts.sec.gov/*",
    "https://data.sec.gov/*",
    "https://blockstream.info/*",
    "https://api.gdeltproject.org/*",
    "https://opensky-network.org/*",
    "https://www.courtlistener.com/*",
    "https://api.opencorporates.com/*",
    "https://api.gleif.org/*",
    "https://hexdb.io/*",
    "https://registry.faa.gov/*",
    "https://www.itu.int/*",
    "https://api.vesselfinder.com/*",
    "https://aeroapi.flightaware.com/*",
    "https://identity.dataspace.copernicus.eu/*",
    "https://sh.dataspace.copernicus.eu/*",
    "https://nominatim.openstreetmap.org/*",
    "identity",
    "downloads"
  ],

  "optional_permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "notifications"
  ],

  "background": {
    "scripts": [
      "lib/storage-db.js",
      "lib/opfs-storage.js",
      "lib/vendor/pdf.min.js",
      "lib/vendor/fflate.min.js",
      "lib/cloud-providers.js",
      "lib/intelligence-providers.js",
      "lib/aircraft-lookup.js",
      "lib/vessel-lookup.js",
      "lib/cloud-backup.js",
      "lib/argus-vault.js",
      "lib/xmpp-client.js",
      "lib/xmpp-sms.js",
      "background-permissions.js",
      "lib/argus-structured.js",
      "background-presets.js",
      "background-providers.js",
      "background.js",
      "background-osint.js",
      "data/kg-dictionaries.js",
      "background-kg.js",
      "background-pipelines.js",
      "background-agents.js",
      "data/prebuilt-automations.js",
      "background-automations.js"
    ],
    "persistent": true
  },

  "web_accessible_resources": [
    "lib/vendor/pdf.worker.min.js",
    "data/resources.json",
    "shared/lock-screen.css"
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Argus",
    "default_popup": "popup/popup.html"
  },

  "commands": {
    "_execute_browser_action": {
      "suggested_key": { "default": "Ctrl+Shift+G" },
      "description": "Open Argus"
    },
    "quick-summary": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Quick Summary of current page"
    },
    "quick-selection": {
      "suggested_key": { "default": "Ctrl+Shift+A" },
      "description": "Analyze selected text"
    }
  }
}
